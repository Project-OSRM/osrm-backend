{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "osrm-backend",
  "version-string": "5-dev",
  "description": "Open Source Routing Machine - high performance routing engine",
  "homepage": "https://github.com/Project-OSRM/osrm-backend",
  "dependencies": [
    "boost-algorithm",
    "boost-any",
    "boost-asio",
    "boost-assert",
    "boost-beast",
    "boost-config",
    "boost-core",
    "boost-crc",
    "boost-date-time",
    "boost-dynamic-bitset",
    "boost-exception",
    "boost-foreach",
    "boost-fusion",
    "boost-geometry",
    "boost-heap",
    "boost-interprocess",
    "boost-io",
    "boost-iostreams",
    "boost-iterator",
    "boost-mpl",
    "boost-numeric-conversion",
    "boost-optional",
    "boost-program-options",
    "boost-range",
    "boost-serialization",
    "boost-spirit",
    "boost-test",
    "boost-thread",
    "boost-tokenizer",
    "boost-uuid",
    "boost-variant",
    "tbb",
    "expat",
    "bzip2",
    "zlib",
    "lua",
    "fmt",
    "rapidjson",
    "sol2",
    "protozero",
    "flatbuffers",
    "libosmium"
  ],
  "overrides": [
    {
      "$comment": "Generated flatbuffers headers in generated/ are pinned to 25.9.23; vcpkg default is 25.12.19. Regenerate the .h files to move this pin forward.",
      "name": "flatbuffers",
      "version": "25.9.23"
    }
  ]
}
